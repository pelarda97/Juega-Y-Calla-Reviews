# =============================================
# FRONTEND ENVIRONMENT VARIABLES (.env)
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!

# Supabase Configuration
# Obtén estas credenciales en: https://supabase.com/dashboard/project/_/settings/api

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (segura para exponer en frontend - protegida por RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================
# EDGE FUNCTION ENVIRONMENT VARIABLES
# =============================================
# Set these in Supabase Dashboard:
# Project Settings > Edge Functions > Secrets

# Admin Authentication Hash
# This is the SHA-256 hash of your admin password
# Generate with: echo -n "your_password" | openssl dgst -sha256
# Or in PowerShell: [System.BitConverter]::ToString((New-Object Security.Cryptography.SHA256Managed).ComputeHash([Text.Encoding]::UTF8.GetBytes("your_password"))).Replace("-","").ToLower()
ADMIN_PASSWORD_HASH=your-sha256-hash-here

# Note: SUPABASE_SERVICE_ROLE_KEY and SUPABASE_URL are automatically available
# in Edge Functions. DO NOT set them manually.

# =============================================
# DEPLOYMENT INSTRUCTIONS
# =============================================
# 1. Install Supabase CLI: npm install -g supabase
# 2. Login: supabase login
# 3. Link project: supabase link --project-ref your-project-id
# 4. Deploy function: supabase functions deploy admin-manage-review
# 5. Set secrets: supabase secrets set ADMIN_PASSWORD_HASH=your-hash

# =============================================
# SECURITY NOTES
# =============================================
# - ANON_KEY: Safe to expose (RLS protects data)
# - SERVICE_ROLE_KEY: NEVER expose to frontend (bypasses RLS)
# - ADMIN_PASSWORD_HASH: Must match sessionStorage admin_token
# - Edge Functions: Service Role Key is server-side only
# - RLS Policies: Block direct client access, Edge Functions bypass with auth

